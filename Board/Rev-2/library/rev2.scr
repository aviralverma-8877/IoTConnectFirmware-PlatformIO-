VALUE Off;
CHANGE Addlevel  Next;
CHANGE Swaplevel 0;
ADD 'PHOTOCELL' 'G$1' (0.000000 0.000000);
PACKAGE 'LDR_OFFBOARD' 1;
CONNECT ALL 'G$1.P$1' '1';
CONNECT ALL 'G$1.P$2' '2';
TECHNOLOGY '''''';
PACKAGE 'LDR_OFFBOARD2' JST;
CONNECT ALL 'G$1.P$1' '+';
