PREFIX '';
VALUE Off;
CHANGE Addlevel  Next;
CHANGE Swaplevel 0;
ADD 'TEMP-HUM-SENSOR-DHT11' 'G$1' (0.000000 0.000000);
PACKAGE 'TEMP-HUM-SENSOR-DHT11' '';
CONNECT ALL 'G$1.DAT' '2';
CONNECT ALL 'G$1.GND' '4';
CONNECT ALL 'G$1.N.C.' '3';
CONNECT ALL 'G$1.VDD' '1';
TECHNOLOGY '''''';

