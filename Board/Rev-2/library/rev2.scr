Edit 'ESP12E*?.DEV';
DESCRIPTION 'ESP12E Module';
PREFIX 'U';
VALUE On;
CHANGE Addlevel  Next;
CHANGE Swaplevel 0;
ADD 'ESP12E' 'G$1' (0.000000 0.000000);
PACKAGE 'ESP12E-SMD' SMD;
CONNECT ALL 'G$1.*GPIO9' 'GPIO9';
CONNECT ALL 'G$1.*GPIO10' 'GPIO10';
CONNECT ALL 'G$1.ADC' 'ADC';
CONNECT ALL 'G$1.CH_PD' 'CH_PD';
CONNECT ALL 'G$1.CS0' 'CS0';
CONNECT ALL 'G$1.GND' 'GND';
CONNECT ALL 'G$1.GPIO0' 'GPIO0';
CONNECT ALL 'G$1.GPIO2' 'GPIO2';
CONNECT ALL 'G$1.GPIO4' 'GPIO4';
CONNECT ALL 'G$1.GPIO5' 'GPIO5';
CONNECT ALL 'G$1.GPIO12' 'GPIO12';
CONNECT ALL 'G$1.GPIO13' 'GPIO13';
CONNECT ALL 'G$1.GPIO14' 'GPIO14';
CONNECT ALL 'G$1.GPIO15' 'GPIO15';
CONNECT ALL 'G$1.GPIO16' 'GPIO16';
CONNECT ALL 'G$1.MISO' 'MISO';
CONNECT ALL 'G$1.MOSI' 'MOSI';
CONNECT ALL 'G$1.RESET' 'RESET';
CONNECT ALL 'G$1.RX' 'RXD0';
CONNECT ALL 'G$1.SCLK' 'SCLK';
CONNECT ALL 'G$1.TX' 'TXD0';
CONNECT ALL 'G$1.VCC' 'VCC';
