Edit '10-XX*?.DEV';
DESCRIPTION '<b>OMRON SWITCH</b>';
PREFIX 'SW';
VALUE On;
CHANGE Addlevel  Next;
CHANGE Swaplevel 0;
ADD 'TS2' '1' (0.000000 0.000000);
PACKAGE 'B3F-10XX' '';
CONNECT ALL '1.P' '3';
CONNECT ALL '1.P1' '4';
CONNECT ALL '1.S' '1';
CONNECT ALL '1.S1' '2';
TECHNOLOGY '''''';
PACKAGE 'BT4.5X4.5' -4.5SMD;
CONNECT ALL '1.P' 'P';
CONNECT ALL '1.P1' 'P1';
CONNECT ALL '1.S' 'S';
CONNECT ALL '1.S1' 'S1';
TECHNOLOGY '''''';
PACKAGE 'BT4X4' 4X4SMD;
CONNECT ALL '1.P' '2';
CONNECT ALL '1.P1' '1';
CONNECT ALL '1.S' '4';
CONNECT ALL '1.S1' '3';
TECHNOLOGY '''''';

